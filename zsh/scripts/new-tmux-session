#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: new-tmux-session <start-dir> [session-name]

Creates a tmux session in <start-dir> with windows: nvim, git, term.
EOF
}

main() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux not found in PATH" >&2
    exit 1
  fi

  local start_dir=${1:-}
  if [[ -z ${start_dir} ]]; then
    usage
    exit 1
  fi

  if [[ ! -d ${start_dir} ]]; then
    echo "Start directory '${start_dir}' does not exist or is not a directory" >&2
    exit 1
  fi

  local abs_start_dir
  abs_start_dir=$(cd "${start_dir}" && pwd)

  local session_name=${2:-$(basename "${abs_start_dir}")}
  local target_session="=${session_name}" # exact tmux target match

  if tmux has-session -t "${target_session}" 2>/dev/null; then
    echo "Session '${session_name}' already exists, switching…" >&2
    switch_or_attach "${target_session}"
    exit 0
  fi

  tmux new-session -d -s "${session_name}" -c "${abs_start_dir}"
  tmux rename-window -t "${target_session}:0" "nvim"
  tmux new-window -d -t "${target_session}:" -n "git" -c "${abs_start_dir}"
  tmux new-window -d -t "${target_session}:" -n "term" -c "${abs_start_dir}"

  tmux send-keys -t "${target_session}:0" "nvim" C-m
  tmux send-keys -t "${target_session}:1" "lg" C-m
  tmux select-window -t "${target_session}:0"

  switch_or_attach "${target_session}"
}

switch_or_attach() {
  local target_session=$1

  if [[ -n ${TMUX:-} ]] && tmux display-message -p '#{client_name}' >/dev/null 2>&1; then
    tmux switch-client -t "${target_session}"
  else
    tmux attach-session -t "${target_session}"
  fi
}

main "$@"
